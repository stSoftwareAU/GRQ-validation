{
  "tasks": {
    "fetch-indices": "deno run --allow-net --allow-read --allow-write scripts/fetch_market_indices.ts"
  },
  "minimumDependencyAge": {
    "age": "P1D",
    "exclude": ["jsr:@stsoftware/*", "npm:@stsoftware/*"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "@std/jsonc": "jsr:@std/jsonc@^1.0.2"
  },
  "exclude": [
    "docs/**/*",
    "src/**/*",
    "Cargo.*",
    "target/**/*",
    "node_modules/**/*"
  ],
  "include": [
    "tests/**/*",
    "helpers/**/*.ts",
    "*.ts"
  ],
  "lint": {
    "include": ["tests/**/*", "helpers/**/*.ts", "*.ts"],
    "exclude": ["docs/**/*", "src/**/*"]
  },
  "fmt": {
    "include": ["tests/**/*", "helpers/**/*.ts", "*.ts"],
    "exclude": ["docs/**/*", "src/**/*"]
  },
  "test": {
    "include": ["tests/**/*"],
    "exclude": ["docs/**/*", "src/**/*"]
  }
}
